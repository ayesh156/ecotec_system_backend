# ─────────────────────────────────────────────────────────────
# ECOTEC SYSTEM - PRODUCTION ENVIRONMENT CONFIGURATION
# Enterprise Shop Management System (POS + ERP + Ecommerce)
# ─────────────────────────────────────────────────────────────

# Environment (development | production)
NODE_ENV=production
PORT=5000

# ── MySQL Database Connection ─────────────────────────────────
# Localhost Example (development):
#   DATABASE_URL="mysql://root:password@localhost:3306/ecotec_db"
# Contabo VPS Example:
#   DATABASE_URL="mysql://ecotec_user:ecotec_pass@localhost:3306/ecotec_db"
# Update user, password, host, and port to match your Contabo MySQL setup.
DATABASE_URL="mysql://user:pass@localhost:3306/ecotec_db"

# ── Authentication & Security ─────────────────────────────────
# Generate strong secrets for production:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="super-secret-key-change-me"
JWT_REFRESH_SECRET="super-secret-refresh-key-change-me"

# ── CORS / Allowed Origins ────────────────────────────────────
# Comma-separated list of allowed origins for CORS.
# Add your custom domain, API subdomain, and localhost for development.
# Wildcard subdomain matching is supported for: .ecosystemlk.app, .ecosystemlk.tech, .ecotec.lk
# Example:
#   ALLOWED_ORIGINS="https://ecotec.lk,https://api.ecotec.lk,https://admin.ecotec.lk,http://localhost:5173"
ALLOWED_ORIGINS="https://ecotec.lk,https://api.ecotec.lk,http://localhost:5173"

# ── Frontend URL (for same-origin SPA serving behind NGINX) ─
FRONTEND_URL="https://ecotec.lk"

# ── Cookie Domain (for cross-subdomain authentication) ────────
# Set this to allow refresh token cookies to work across subdomains.
# Example: COOKIE_DOMAIN=".ecotec.lk"
# COOKIE_DOMAIN=".ecotec.lk"

# ── Single-Shop Mode (Single-Tenant deployment) ──────────────
# Set this to the ID of the default shop.
# The system will use this shop ID for all operations instead of multi-tenant logic.
DEFAULT_SHOP_ID="cmrxeqnn700002ol4njqs47aw"

# ── Email (SMTP) Configuration ────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ── Upload Storage ───────────────────────────────────────────
# UPLOAD_DIR=uploads